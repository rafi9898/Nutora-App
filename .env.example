EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_SUPABASE_STORAGE_BUCKET=meal-photos
EXPO_PUBLIC_DATA_MODE=mock
EXPO_PUBLIC_AI_ANALYSIS_MODE=mock
EXPO_PUBLIC_AI_ANALYSIS_EDGE_FUNCTION=analyze-meal-photo
EXPO_PUBLIC_PAYMENTS_MODE=demo
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
EXPO_PUBLIC_PREMIUM_MONTHLY_PRODUCT_ID=nutora_premium_monthly
EXPO_PUBLIC_PREMIUM_YEARLY_PRODUCT_ID=nutora_premium_yearly
EXPO_PUBLIC_APP_URL=https://nutora.pro
EXPO_PUBLIC_SUPPORT_EMAIL=contact@nutora.pro
EXPO_PUBLIC_CONTACT_EMAIL=contact@nutora.pro

# Optional custom VPS/backend endpoint. Use this for the backend prepared in ./backend.
# Do not put private AI provider keys in the mobile app. The backend must own them.
EXPO_PUBLIC_AI_ANALYSIS_ENDPOINT=https://api.nutora.pro/ai/analyze-meal

# Supabase Edge Function secrets, never expose these as EXPO_PUBLIC_* in mobile:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4-mini
# FREE_ANALYSIS_LIMIT=5
# REVENUECAT_WEBHOOK_SECRET=...
# SUPABASE_SERVICE_ROLE_KEY=...
