NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=*

# Local development only. Set to false in production.
ALLOW_DEV_AUTH_BYPASS=true

# Supabase backend credentials. Service role must stay server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider. If OPENAI_API_KEY is empty, backend returns a deterministic mock analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
FREE_ANALYSIS_LIMIT=5

# RevenueCat webhook secret. Configure the same value in RevenueCat dashboard.
REVENUECAT_WEBHOOK_SECRET=
